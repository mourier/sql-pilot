<UserControl x:Class="SqlPilot.UI.Controls.SearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SqlPilot.UI.Converters"
             Focusable="True"
             Loaded="OnControlLoaded">
  <UserControl.Resources>
    <converters:ObjectTypeToIconConverter x:Key="ObjectTypeToIcon" />
    <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Search Box -->
    <Border Grid.Row="0" Padding="4" Background="{DynamicResource SearchBoxBackground}">
      <TextBox x:Name="SearchTextBox"
               Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
               FontSize="13"
               Padding="6,4"
               VerticalContentAlignment="Center">
        <TextBox.Style>
          <Style TargetType="TextBox">
            <Style.Triggers>
              <Trigger Property="Text" Value="">
                <Setter Property="Background">
                  <Setter.Value>
                    <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                      <VisualBrush.Visual>
                        <Label Content="Search objects... (Ctrl+Shift+D)"
                               Foreground="Gray" FontSize="13" Padding="6,4" />
                      </VisualBrush.Visual>
                    </VisualBrush>
                  </Setter.Value>
                </Setter>
              </Trigger>
            </Style.Triggers>
          </Style>
        </TextBox.Style>
      </TextBox>
    </Border>

    <!-- Results List with virtualization -->
    <ListBox Grid.Row="1"
             x:Name="ResultsListBox"
             ItemsSource="{Binding Results}"
             SelectedItem="{Binding SelectedResult}"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.CanContentScroll="True"
             VirtualizingStackPanel.IsVirtualizing="True"
             VirtualizingStackPanel.VirtualizationMode="Recycling"
             BorderThickness="0"
             MouseDoubleClick="ResultsListBox_MouseDoubleClick"
             PreviewKeyDown="ResultsListBox_PreviewKeyDown"
             Background="{DynamicResource ResultsBackground}">
      <ListBox.ContextMenu>
        <ContextMenu Opened="ContextMenu_Opened">
          <MenuItem Header="(loading...)" />
        </ContextMenu>
      </ListBox.ContextMenu>
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <VirtualizingStackPanel />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid Margin="2,1" MinHeight="32">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="24" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Object Type Icon -->
            <TextBlock Grid.Column="0"
                       Text="{Binding ObjectType, Converter={StaticResource ObjectTypeToIcon}}"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="14"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource IconForeground}" />

            <!-- Object Name + Type, with optional server line below -->
            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="4,0">
              <TextBlock TextTrimming="CharacterEllipsis">
                <Run Text="{Binding DisplayName, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"
                     Foreground="{DynamicResource PrimaryForeground}" />
                <Run Text="{Binding ObjectTypeName, Mode=OneWay}" FontSize="10"
                     Foreground="{DynamicResource SecondaryForeground}" />
              </TextBlock>
              <TextBlock Text="{Binding ShortServerName}"
                         FontSize="9"
                         Opacity="0.75"
                         TextTrimming="CharacterEllipsis"
                         Foreground="{DynamicResource SecondaryForeground}"
                         ToolTip="{Binding ServerName}"
                         Visibility="{Binding ShowServer, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <!-- Database Badge -->
            <TextBlock Grid.Column="2"
                       Text="{Binding DatabaseName}"
                       FontSize="10"
                       VerticalAlignment="Center"
                       Margin="4,0"
                       Foreground="{DynamicResource SecondaryForeground}" />

            <!-- Favorite Star -->
            <TextBlock Grid.Column="3"
                       Text="&#x2605;"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="2,0"
                       Foreground="Gold"
                       Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Status Bar -->
    <Border Grid.Row="2" Padding="4,2" Background="{DynamicResource StatusBarBackground}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Text="{Binding StatusText}"
                   FontSize="10"
                   Foreground="{DynamicResource SecondaryForeground}" />
        <TextBlock Grid.Column="1"
                   Text="{Binding ResultCount, StringFormat='{}{0} items'}"
                   FontSize="10"
                   Foreground="{DynamicResource SecondaryForeground}" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
