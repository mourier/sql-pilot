<Application x:Class="SqlPilot.Installer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>

      <!-- Friendly palette — soft blues to match the logo -->
      <Color x:Key="AccentColor">#2B6CB0</Color>
      <Color x:Key="AccentHoverColor">#3B7CC0</Color>
      <Color x:Key="AccentPressedColor">#1B5CA0</Color>
      <Color x:Key="WindowBgColor">#FAFBFC</Color>
      <Color x:Key="CardBgColor">#FFFFFF</Color>
      <Color x:Key="MutedTextColor">#6B7280</Color>
      <Color x:Key="HairlineColor">#E5E7EB</Color>
      <Color x:Key="WarnBgColor">#FEF3C7</Color>
      <Color x:Key="WarnFgColor">#92400E</Color>
      <Color x:Key="OkColor">#059669</Color>

      <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
      <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
      <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
      <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}" />
      <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}" />
      <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
      <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource HairlineColor}" />
      <SolidColorBrush x:Key="WarnBgBrush" Color="{StaticResource WarnBgColor}" />
      <SolidColorBrush x:Key="WarnFgBrush" Color="{StaticResource WarnFgColor}" />
      <SolidColorBrush x:Key="OkBrush" Color="{StaticResource OkColor}" />

      <!-- Rounded primary button (the Install / Close action) -->
      <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="20,8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}"
                      CornerRadius="6"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
          </Trigger>
          <Trigger Property="IsPressed" Value="True">
            <Setter Property="Background" Value="{StaticResource AccentPressedBrush}" />
          </Trigger>
          <Trigger Property="IsEnabled" Value="False">
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Cursor" Value="Arrow" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Rounded secondary button (Cancel, Uninstall) -->
      <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}"
                      BorderBrush="{StaticResource HairlineBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="#F3F4F6" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Friendly default font everywhere -->
      <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
      </Style>
      <Style TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
      </Style>
      <Style TargetType="CheckBox">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
      </Style>

    </ResourceDictionary>
  </Application.Resources>
</Application>
